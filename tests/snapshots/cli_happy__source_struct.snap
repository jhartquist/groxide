struct groxide_test_api::GenericStruct
pub struct GenericStruct<T: Clone>

A generic container holding a single value.

Examples

  use groxide_test_api::GenericStruct;
  let gs = GenericStruct::new(42);
  assert_eq!(*gs.value(), 42);

