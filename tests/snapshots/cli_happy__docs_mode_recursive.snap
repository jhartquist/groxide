struct  groxide_test_api::containers::Stack
    pub struct Stack<T>

    A stack data structure backed by a Vec.

    Examples

      use groxide_test_api::containers::Stack;
      let mut s = Stack::new();
      s.push(1);
      s.push(2);
      assert_eq!(s.pop(), Some(2));
